# =============================================================================
# Tevel FCF-R3 Context Engine — Environment Variables
# Copy this file to .env.local and fill in your values.
# NEVER commit .env.local or any file that contains real secrets.
# =============================================================================

# ── Local LLM (Ollama) ───────────────────────────────────────────────────────
# Required for local reasoning, extraction, and deterministic fallback.
# Install Ollama: https://ollama.com/
# Pull models: ollama pull qwen3.5:4b && ollama pull nomic-embed-text

OLLAMA_BASE_URL=http://127.0.0.1:11434
OLLAMA_MODEL=qwen3.5:4b
OLLAMA_FAST_MODEL=qwen3.5:4b
OLLAMA_EMBED_MODEL=nomic-embed-text

# ── Gemini Cloud (optional) ───────────────────────────────────────────────────
# Leave blank to run in local-only / deterministic-fallback mode.
# Set TEVEL_USE_GEMINI=true to route cloud requests through Gemini.
# Get a key at: https://aistudio.google.com/app/apikey

GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash
TEVEL_USE_GEMINI=false

# ── Supabase (optional persistence) ──────────────────────────────────────────
# Leave blank to use in-memory repositories (suitable for dev / testing).
# When set, FCF-R3 runs, selected evidence, and citation results are persisted.

VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
TEVEL_SUPABASE_URL=
TEVEL_SUPABASE_ANON_KEY=

# ── Timeouts (ms) ────────────────────────────────────────────────────────────
TEVEL_REASONING_TIMEOUT_MS=45000
TEVEL_FAST_QA_TIMEOUT_MS=15000
TEVEL_LOCAL_MODEL_ATTEMPT_TIMEOUT_MS=30000

# ── Sidecar / Python runtime ──────────────────────────────────────────────────
# Set to the path of the Python binary in the sidecar venv.
# Run: bash scripts/setup_sidecar_runtime.sh to create the venv.

TEVEL_PYTHON_BIN=.venv-sidecar/bin/python

# ── Reference knowledge stores (optional) ────────────────────────────────────
# TEVEL_REFERENCE_STORE_MODE: "supabase" | "memory" (default: memory)
# TEVEL_REFERENCE_CASE_TABLE: Supabase table name for reference knowledge
# TEVEL_YENTE_API_BASE: Base URL for a running Yente entity matching service
# TEVEL_PELIAS_API_BASE: Base URL for a running Pelias geocoding service
# TEVEL_PELIAS_API_KEY: API key for the Pelias service (if required)
# TEVEL_GRAPHITI_SINK_ENABLED: "true" | "false" (default: false)
# TEVEL_GRAPHITI_SINK_URL: URL for Graphiti graph store

TEVEL_REFERENCE_STORE_MODE=memory
TEVEL_REFERENCE_CASE_TABLE=
TEVEL_YENTE_API_BASE=
TEVEL_PELIAS_API_BASE=
TEVEL_PELIAS_API_KEY=
TEVEL_GRAPHITI_SINK_ENABLED=false
TEVEL_GRAPHITI_SINK_URL=

# ── Benchmark settings ────────────────────────────────────────────────────────
BENCHMARK_RUNS=3
BENCHMARK_GEMINI_TIMEOUT_MS=60000
